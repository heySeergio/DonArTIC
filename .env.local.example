# Neon (pooler recomendado para serverless)
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
#
# Tras configurar DATABASE_URL, crea la tabla una vez:
#   npm run db:setup
# (o pega db/schema.sql en el SQL Editor de Neon)

# Alternativas que también reconoce la app
# POSTGRES_PRISMA_URL="..."
# POSTGRES_URL="..."

ADMIN_PASSWORD="cambia_esta_clave"
